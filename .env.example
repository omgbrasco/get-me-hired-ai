ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key
ADZUNA_COUNTRY=us
PORT=3000

# Optional: set to true to include debugMessage in /api/search JSON (default off; details still logged server-side)
# EXPOSE_SEARCH_DEBUG=true

# Waitlist storage — optional, falls back to local JSON if not set
AIRTABLE_API_KEY=your_airtable_api_key
AIRTABLE_BASE_ID=your_airtable_base_id
AIRTABLE_TABLE_NAME=Waitlist
